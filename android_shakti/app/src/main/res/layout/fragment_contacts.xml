<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_primary"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contacts"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Contact 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_dark_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Contact 1"
                    android:textColor="@color/shakti_red"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etContact1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="+91 9876543210"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:inputType="phone"/>
            </LinearLayout>

            <!-- Contact 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_dark_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Contact 2"
                    android:textColor="@color/shakti_red"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etContact2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="+91 9876543210"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:inputType="phone"/>
            </LinearLayout>

            <!-- Guardian Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_dark_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardian Email"
                    android:textColor="@color/shakti_red"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etGuardianEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="guardian@example.com"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textEmailAddress"/>
            </LinearLayout>

            <!-- Save Button - Red -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Contacts"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="@color/shakti_red"
                android:layout_marginBottom="12dp"/>

            <!-- Test Alert Button -->
            <Button
                android:id="@+id/btnTestAlert"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"
                android:text="Send Test Alert"
                android:textColor="@color/shakti_red"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="@color/bg_dark_surface"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
