<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contacts"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <!-- Contact 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contact 1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
                
            <EditText
                android:id="@+id/etContact1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+91 9876543210"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary"
                android:inputType="phone"/>
        </LinearLayout>

        <!-- Contact 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contact 2"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etContact2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+91 9876543210"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary"
                android:inputType="phone"/>
        </LinearLayout>

        <!-- Guardian Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guardian Email"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/etGuardianEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="guardian@example.com"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary"
                android:inputType="textEmailAddress"/>
        </LinearLayout>
        
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Contacts"
            android:textColor="@color/white"
            android:backgroundTint="@color/shakti_red"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
