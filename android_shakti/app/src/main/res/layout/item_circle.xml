<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Circle Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Circle Icon -->
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="👥"
                android:textSize="32sp"
                android:gravity="center"
                android:background="@drawable/circle_icon_background" />

            <!-- Circle Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvCircleName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Family Circle"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937" />

                <TextView
                    android:id="@+id/tvMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 members"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Delete Button -->
            <ImageButton
                android:id="@+id/btnDeleteCircle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#EF4444"
                android:padding="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Invite Code (for admins) -->
        <LinearLayout
            android:id="@+id/inviteCodeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/invite_code_background">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Invite Code:"
                android:textSize="12sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvInviteCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABC123"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#8B5CF6"
                android:fontFamily="monospace" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_share"
                android:tint="#8B5CF6"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
