<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E3C72"
        app:tabTextColor="#A0FFFFFF"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#25D366"
        app:tabMode="fixed">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan QR Code" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Phone Number" />

    </com.google.android.material.tabs.TabLayout>

    <!-- CONTENT CONTAINER -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- QR CODE VIEW -->
        <RelativeLayout
            android:id="@+id/qrContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminateTint="#25D366" />

            <WebView
                android:id="@+id/whatsappWebView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
                
        </RelativeLayout>

        <!-- PHONE NUMBER VIEW -->
        <ScrollView
            android:id="@+id/phoneContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:padding="20dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/stat_sys_phone_call"
                    app:tint="#25D366"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="40dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Connect"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1E3C72"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect by entering your Guardian's phone number directly. We will send a connection request."
                    android:gravity="center"
                    android:textColor="#666666"
                    android:layout_marginBottom="30dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Guardian's Phone Number (with Country Code)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGuardianPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:text="+91"
                        android:drawableStart="@android:drawable/ic_menu_call"
                        android:drawablePadding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Example: +919990758187"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_gravity="start"
                    android:layout_marginLeft="5dp"
                    android:layout_marginBottom="30dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectPhone"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Link with Phone Number"
                    android:backgroundTint="#25D366"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"/>
                    
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
