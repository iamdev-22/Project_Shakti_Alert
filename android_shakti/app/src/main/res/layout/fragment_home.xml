<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_primary"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHAKTI ALERT"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- AI Help Button -->
    <ImageButton
        android:id="@+id/btnAiHelp"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_help"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/shakti_red"
        android:contentDescription="AI Help"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Secured"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:background="@drawable/bg_pill_white"
        android:backgroundTint="#1AFF2020"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Voice Animation Container (ChatGPT Dot Wave Style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/voiceContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintBottom_toTopOf="@id/controlsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dot Wave Circle Container -->
        <FrameLayout
            android:id="@+id/dotWaveContainer"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </FrameLayout>

        <!-- Microphone Icon in Center -->
        <ImageView
            android:id="@+id/micIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/shakti_red"
            app:layout_constraintTop_toTopOf="@id/dotWaveContainer"
            app:layout_constraintBottom_toBottomOf="@id/dotWaveContainer"
            app:layout_constraintStart_toStartOf="@id/dotWaveContainer"
            app:layout_constraintEnd_toEndOf="@id/dotWaveContainer"
            android:elevation="5dp"/>

        <!-- Trigger Button Overlay -->
        <View
            android:id="@+id/btnTrigger"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- START button - Red -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartService"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="START"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/shakti_red"
                app:icon="@android:drawable/ic_media_play"
                app:iconTint="@color/white"
                app:cornerRadius="30dp"
                android:layout_marginEnd="8dp" />

            <!-- STOP button - Dark -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopService"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="STOP"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/bg_dark_surface"
                app:icon="@android:drawable/ic_media_pause"
                app:iconTint="@color/text_secondary"
                app:cornerRadius="30dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Voice Setup button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnroll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="VOICE SETUP"
            android:textSize="14sp"
            android:textColor="@color/shakti_red"
            android:backgroundTint="@color/bg_dark_surface"
            app:strokeColor="@color/shakti_red"
            app:strokeWidth="1dp"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconTint="@color/shakti_red"
            android:layout_marginHorizontal="32dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
